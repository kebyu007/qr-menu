<style>
  .page-nav {
    background: rgba(250,246,240,0.95); backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem; display: flex; align-items: center;
    justify-content: space-between; height: 64px;
    position: sticky; top: 0; z-index: 100;
  }
  .nav-brand { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: var(--brown); text-decoration: none; }
  .nav-brand span { color: var(--gold); }
  .nav-links { display: flex; gap: 0.5rem; align-items: center; }
  .nav-links a { padding: 0.5rem 1rem; border-radius: 8px; color: var(--text-muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: all 0.2s; }
  .nav-links a:hover { background: var(--border); color: var(--brown); }

  .container { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; }

  /* Product hero */
  .product-hero { padding: 2.5rem 0; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  .product-img-wrap { border-radius: 20px; overflow: hidden; aspect-ratio: 4/3; background: linear-gradient(135deg, var(--brown-light), var(--gold)); display: flex; align-items: center; justify-content: center; font-size: 6rem; }
  .product-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .product-cat { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold); margin-bottom: 0.75rem; }
  .product-name { font-family: 'Playfair Display', serif; font-size: 2.4rem; font-weight: 700; color: var(--brown); line-height: 1.15; margin-bottom: 1rem; }
  .product-rating { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; }
  .stars-display { color: var(--gold); font-size: 1.1rem; }
  .rating-count { font-size: 0.85rem; color: var(--text-muted); }
  .product-price { font-size: 2rem; font-weight: 700; color: var(--brown-mid); margin-bottom: 1.25rem; }
  .product-price span { font-size: 1rem; font-weight: 400; color: var(--text-muted); }
  .product-desc { color: var(--text-muted); line-height: 1.8; font-size: 0.95rem; margin-bottom: 2rem; }
  .divider { height: 1px; background: var(--border); margin: 2.5rem 0; }

  /* Feedback form */
  .feedback-section { padding-bottom: 3rem; }
  .section-title { font-family: 'Playfair Display', serif; font-size: 1.6rem; color: var(--brown); margin-bottom: 1.5rem; }
  .feedback-form-card { background: var(--warm-white); border: 1px solid var(--border); border-radius: 16px; padding: 1.75rem; margin-bottom: 2rem; }

  /* Star rating */
  .star-rating { display: flex; flex-direction: row-reverse; gap: 0.4rem; margin-top: 0.5rem; }
  .star-rating input { display: none; }
  .star-rating label { font-size: 1.8rem; cursor: pointer; color: var(--border); transition: color 0.15s; line-height: 1; }
  .star-rating input:checked ~ label,
  .star-rating label:hover,
  .star-rating label:hover ~ label { color: var(--gold); }

  /* Feedback cards */
  .feedback-list { display: flex; flex-direction: column; gap: 1rem; }
  .feedback-card { background: var(--warm-white); border: 1px solid var(--border); border-radius: 14px; padding: 1.25rem; animation: fadeUp 0.4s ease both; }
  .feedback-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; }
  .feedback-user-name { font-weight: 600; font-size: 0.9rem; }
  .feedback-date { font-size: 0.78rem; color: var(--text-muted); }
  .feedback-text { font-size: 0.9rem; color: var(--text); line-height: 1.6; }
  .feedback-img { width: 100%; max-height: 200px; object-fit: cover; border-radius: 8px; margin-top: 0.75rem; }
  .no-feedback { text-align: center; padding: 3rem; color: var(--text-muted); }
  .login-prompt { background: var(--warm-white); border: 1px solid var(--border); border-radius: 14px; padding: 1.5rem; text-align: center; color: var(--text-muted); }
  .login-prompt a { color: var(--brown); font-weight: 600; text-decoration: none; }

  @media (max-width: 768px) {
    .product-hero { grid-template-columns: 1fr; gap: 1.5rem; }
    .product-name { font-size: 1.8rem; }
  }
</style>

<nav class="page-nav">
  <a href="/menu" class="nav-brand">QR<span>Menu</span></a>
  <div class="nav-links">
    <a href="/menu">← Menuga qaytish</a>
    {{#if user}}<a href="/profile">👤 {{user.name}}</a>{{else}}<a href="/login" style="background:var(--brown);color:var(--cream);border-radius:50px;padding:0.5rem 1.25rem;">Kirish</a>{{/if}}
  </div>
</nav>

<div class="container">
  <div class="product-hero fade-up">
    <!-- Rasm -->
    <div class="product-img-wrap">
      {{#if product.imageUrl}}
        <img src="{{product.imageUrl}}" alt="{{product.name}}">
      {{else}}
        🍜
      {{/if}}
    </div>

    <!-- Ma'lumot -->
    <div>
      <div class="product-cat">{{product.category.name}}</div>
      <div class="product-name">{{product.name}}</div>

      <div class="product-rating">
        {{#if avgStars}}
          <div class="stars-display">
            {{#times 5}}
              <span style="color: {{#if (lte @index ../avgStars)}}var(--gold){{else}}var(--border){{/if}}">★</span>
            {{/times}}
          </div>
          <span style="font-weight:700; color:var(--brown);">{{avgStars}}</span>
          <span class="rating-count">({{feedbacks.length}} ta baho)</span>
        {{else}}
          <span class="rating-count">Hali baho yo'q</span>
        {{/if}}
      </div>

      <div class="product-price">{{product.price}} <span>so'm</span></div>

      {{#if product.description}}
      <div class="product-desc">{{product.description}}</div>
      {{/if}}
    </div>
  </div>

  <div class="divider"></div>

  <!-- Feedback -->
  <div class="feedback-section">
    <div class="section-title">Mijozlar fikrlari</div>

    {{#if user}}
    <div class="feedback-form-card">
      <form action="/menu/{{product._id}}/feedback" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label class="form-label">Bahoyingiz</label>
          <div class="star-rating">
            <input type="radio" name="stars" id="s5" value="5"><label for="s5">★</label>
            <input type="radio" name="stars" id="s4" value="4"><label for="s4">★</label>
            <input type="radio" name="stars" id="s3" value="3" checked><label for="s3">★</label>
            <input type="radio" name="stars" id="s2" value="2"><label for="s2">★</label>
            <input type="radio" name="stars" id="s1" value="1"><label for="s1">★</label>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Fikringiz</label>
          <textarea name="text" class="form-control" rows="3" placeholder="Bu taom haqida nima deysiz?" required style="resize:vertical;"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Rasm (ixtiyoriy)</label>
          <input type="file" name="image" class="form-control" accept="image/*">
        </div>
        <button type="submit" class="btn btn-primary">Yuborish ✦</button>
      </form>
    </div>
    {{else}}
    <div class="login-prompt">
      Feedback qoldirish uchun <a href="/login">tizimga kiring</a>
    </div>
    {{/if}}

    <div style="height:1.5rem;"></div>

    {{#if feedbacks.length}}
    <div class="feedback-list">
      {{#each feedbacks}}
      <div class="feedback-card" style="animation-delay:{{@index}}00ms">
        <div class="feedback-header">
          <div>
            <div class="feedback-user-name">{{user.name}}</div>
            <div class="stars" style="font-size:0.9rem;">{{#times stars}}★{{/times}}</div>
          </div>
          <div class="feedback-date">{{createdAt}}</div>
        </div>
        <div class="feedback-text">{{text}}</div>
        {{#if imageUrl}}
        <img src="{{imageUrl}}" alt="feedback" class="feedback-img">
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="no-feedback">💬 Hali hech kim fikr qoldirmagan. Birinchi bo'ling!</div>
    {{/if}}
  </div>
</div>
