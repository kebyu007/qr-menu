<style>
  .page-nav { background:rgba(250,246,240,0.95); backdrop-filter:blur(16px); border-bottom:1px solid var(--border); padding:0 1.5rem; display:flex; align-items:center; justify-content:space-between; height:60px; position:sticky; top:0; z-index:100; }
  .nav-brand { font-family:'Playfair Display',serif; font-size:1.4rem; font-weight:700; color:var(--brown); text-decoration:none; }
  .nav-brand span { color:var(--gold); }
  .back-btn { display:inline-flex; align-items:center; gap:0.4rem; padding:0.45rem 1rem; border-radius:8px; color:var(--text-muted); text-decoration:none; font-size:0.875rem; font-weight:500; transition:all 0.2s; }
  .back-btn:hover { background:var(--border); color:var(--brown); }

  .container { max-width:960px; margin:0 auto; padding:0 1.25rem; }

  .product-hero { padding:2rem 0; display:grid; grid-template-columns:1fr 1fr; gap:2.5rem; align-items:start; }
  .product-img-wrap { border-radius:20px; overflow:hidden; aspect-ratio:4/3; background:linear-gradient(135deg,var(--brown-light),var(--gold)); display:flex; align-items:center; justify-content:center; font-size:5rem; }
  .product-img-wrap img { width:100%; height:100%; object-fit:cover; }
  .product-info { padding-top:0.5rem; }
  .product-cat { font-size:0.78rem; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; color:var(--gold); margin-bottom:0.6rem; }
  .product-name { font-family:'Playfair Display',serif; font-size:clamp(1.6rem,3vw,2.2rem); font-weight:700; color:var(--brown); line-height:1.2; margin-bottom:0.9rem; }
  .product-rating { display:flex; align-items:center; gap:0.6rem; margin-bottom:1rem; flex-wrap:wrap; }
  .stars-display { color:var(--gold); font-size:1rem; }
  .rating-num { font-weight:700; color:var(--brown); }
  .rating-count { font-size:0.82rem; color:var(--text-muted); }
  .product-price { font-size:1.8rem; font-weight:700; color:var(--brown-mid); margin-bottom:1rem; }
  .product-price span { font-size:0.85rem; font-weight:400; color:var(--text-muted); }
  .product-desc { color:var(--text-muted); line-height:1.75; font-size:0.9rem; }
  .divider { height:1px; background:var(--border); margin:2rem 0; }

  /* Feedback */
  .section-title { font-family:'Playfair Display',serif; font-size:1.4rem; color:var(--brown); margin-bottom:1.25rem; }
  .feedback-form-card { background:var(--warm-white); border:1px solid var(--border); border-radius:16px; padding:1.5rem; margin-bottom:1.75rem; }

  .star-rating { display:flex; flex-direction:row-reverse; gap:0.35rem; margin-top:0.5rem; }
  .star-rating input { display:none; }
  .star-rating label { font-size:1.7rem; cursor:pointer; color:var(--border); transition:color 0.15s; line-height:1; }
  .star-rating input:checked ~ label,
  .star-rating label:hover,
  .star-rating label:hover ~ label { color:var(--gold); }

  .feedback-list { display:flex; flex-direction:column; gap:0.9rem; padding-bottom:3rem; }
  .feedback-card { background:var(--warm-white); border:1px solid var(--border); border-radius:14px; padding:1.1rem; animation:fadeUp 0.4s ease both; }
  .feedback-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:0.6rem; gap:0.5rem; }
  .feedback-user-name { font-weight:600; font-size:0.875rem; }
  .feedback-date { font-size:0.75rem; color:var(--text-muted); white-space:nowrap; }
  .feedback-text { font-size:0.875rem; color:var(--text); line-height:1.6; }
  .feedback-img { width:100%; max-height:180px; object-fit:cover; border-radius:8px; margin-top:0.65rem; }
  .no-feedback { text-align:center; padding:2.5rem; color:var(--text-muted); font-size:0.9rem; }
  .login-prompt { background:var(--warm-white); border:1.5px dashed var(--border); border-radius:14px; padding:1.5rem; text-align:center; }
  .login-prompt p { color:var(--text-muted); margin-bottom:0.9rem; font-size:0.9rem; }
  .login-prompt a { color:var(--brown); font-weight:600; text-decoration:none; }

  @media(max-width:768px) {
    .product-hero { grid-template-columns:1fr; gap:1.25rem; }
    .product-img-wrap { aspect-ratio:16/9; border-radius:14px; }
  }
  @media(max-width:480px) {
    .feedback-form-card { padding:1.1rem; }
    .star-rating label { font-size:1.5rem; }
  }
</style>

<nav class="page-nav">
  <a href="/menu" class="nav-brand">QR<span>Menu</span></a>
  <a href="/menu" class="back-btn">← Orqaga</a>
</nav>

<div class="container">
  <div class="product-hero fade-up">
    <div class="product-img-wrap">
      {{#if product.imageUrl}}
        <img src="{{product.imageUrl}}" alt="{{product.name}}">
      {{else}}🍜{{/if}}
    </div>
    <div class="product-info">
      <div class="product-cat">{{product.category.name}}</div>
      <div class="product-name">{{product.name}}</div>
      <div class="product-rating">
        {{#if avgStars}}
          <div class="stars-display">
            {{#times 5}}★{{/times}}
          </div>
          <span class="rating-num">{{avgStars}}</span>
          <span class="rating-count">({{feedbacks.length}} ta baho)</span>
        {{else}}
          <span class="rating-count">Hali baho yo'q — birinchi bo'ling!</span>
        {{/if}}
      </div>
      <div class="product-price">{{product.price}} <span>so'm</span></div>
      {{#if product.description}}
      <div class="product-desc">{{product.description}}</div>
      {{/if}}
    </div>
  </div>

  <div class="divider"></div>

  <div class="section-title">Mijozlar fikrlari</div>

  {{#if user}}
  <div class="feedback-form-card">
    <form action="/menu/{{product._id}}/feedback" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label class="form-label">Bahoyingiz</label>
        <div class="star-rating">
          <input type="radio" name="stars" id="s5" value="5"><label for="s5">★</label>
          <input type="radio" name="stars" id="s4" value="4"><label for="s4">★</label>
          <input type="radio" name="stars" id="s3" value="3" checked><label for="s3">★</label>
          <input type="radio" name="stars" id="s2" value="2"><label for="s2">★</label>
          <input type="radio" name="stars" id="s1" value="1"><label for="s1">★</label>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Fikringiz</label>
        <textarea name="text" class="form-control" rows="3" placeholder="Bu taom haqida nima deysiz?" required></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Rasm (ixtiyoriy)</label>
        <input type="file" name="image" class="form-control" accept="image/*">
      </div>
      <button type="submit" class="btn btn-primary">Yuborish ✦</button>
    </form>
  </div>
  {{else}}
  <div class="login-prompt">
    <p>Fikr qoldirish uchun tizimga kiring</p>
    <a href="/login" style="color: aliceblue;" class="btn btn-primary">Kirish</a>
    &nbsp;
    <a href="/register" class="btn btn-outline">Ro'yxatdan o'tish</a>
  </div>
  {{/if}}

  {{#if feedbacks.length}}
  <div class="feedback-list" style="margin-top:1.5rem;">
    {{#each feedbacks}}
    <div class="feedback-card" style="animation-delay:{{@index}}0ms">
      <div class="feedback-header">
        <div>
          <div class="feedback-user-name">{{user.name}}</div>
          <div class="stars" style="font-size:0.85rem;">{{#times stars}}★{{/times}}</div>
        </div>
        <div class="feedback-date">{{createdAt}}</div>
      </div>
      <div class="feedback-text">{{text}}</div>
      {{#if imageUrl}}<img src="{{imageUrl}}" alt="feedback" class="feedback-img">{{/if}}
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="no-feedback" style="margin-top:1rem;">💬 Hali fikr yo'q</div>
  {{/if}}
</div>
