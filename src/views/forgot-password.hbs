<style>
  .auth-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem; background: var(--cream); }
  .auth-box { width: 100%; max-width: 440px; animation: fadeUp 0.6s ease; }
  .back-link { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--text-muted); text-decoration: none; font-size: 0.9rem; margin-bottom: 2rem; transition: color 0.2s; }
  .back-link:hover { color: var(--brown); }
  .auth-icon { width: 72px; height: 72px; background: var(--brown); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 1.5rem; }
  .auth-title { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: var(--brown); margin-bottom: 0.5rem; }
  .auth-sub { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 2rem; line-height: 1.6; }
</style>

<div class="auth-page">
  <div class="auth-box">
    <a href="/login" class="back-link">← Orqaga</a>
    <div class="auth-icon">🔑</div>
    <div class="auth-title">Parolni tiklash</div>
    <div class="auth-sub">Email manzilingizni kiriting. Parolni tiklash havolasini yuboramiz.</div>


    <form action="/api/auth/forgot-password" method="POST">
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" placeholder="email@example.com" required>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding: 0.85rem;">
        Havola yuborish
      </button>
    </form>
  </div>
</div>
