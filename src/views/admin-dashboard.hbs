<section class="hero">
  <div>
    <h1 class="page-title">Admin Dashboard</h1>
    <p class="page-subtitle">Kategoriyalar, mahsulotlar va feedback nazorati bitta joyda.</p>
  </div>
</section>

<section class="grid-3 section">
  <article class="card panel">
    <h3>{{categories.length}}</h3>
    <p class="muted">Categories</p>
  </article>
  <article class="card panel">
    <h3>{{products.length}}</h3>
    <p class="muted">Products</p>
  </article>
  <article class="card panel">
    <h3>{{feedbacks.length}}</h3>
    <p class="muted">Feedback entries</p>
  </article>
</section>

<section class="grid-2 section">
  <section id="create-category" class="card panel">
    <h3>Create Category</h3>
    <form action="/api/categories" method="POST">
      <label for="categoryName">Name</label>
      <input class="input" id="categoryName" name="name" required />
      <button class="btn" type="submit">Create Category</button>
    </form>
  </section>

  <section id="create-product" class="card panel">
    <h3>Create Product</h3>
    <form action="/api/products" method="POST" enctype="multipart/form-data">
      <label for="productName">Name</label>
      <input class="input" id="productName" name="name" required />
      <label for="productPrice">Price</label>
      <input class="input" id="productPrice" type="number" step="0.01" name="price" required />
      <label for="productDescription">Description</label>
      <textarea class="input" id="productDescription" name="description" rows="3" placeholder="Short product description"></textarea>
      <label for="productCategory">Category</label>
      <select id="productCategory" name="category_id">
        {{#each categories}}
          <option value="{{this._id}}">{{this.name}}</option>
        {{/each}}
      </select>
      <label for="productImage">Image</label>
      <input class="input" id="productImage" type="file" name="image" />
      <button class="btn" type="submit">Create Product</button>
    </form>
  </section>
</section>

<section class="card panel">
  <h3>Categories</h3>
  <div class="grid">
    {{#each categories}}
      <div class="card">
        <strong>{{this.name}}</strong>
      </div>
    {{/each}}
  </div>
</section>

<section class="card panel">
  <h3>Products</h3>
  <div class="grid">
    {{#each products}}
      <div class="card">
        <strong>{{this.name}}</strong>
        <p>{{this.category.name}} - {{this.price}}</p>
        {{#if this.description}}
          <p class="muted">{{this.description}}</p>
        {{/if}}
      </div>
    {{/each}}
  </div>
</section>

<section class="card panel">
  <h3>Feedback</h3>
  <p class="muted">Complaint feedback avtomatik ajratib ko‘rsatilgan.</p>
  {{#each feedbacks}}
    <div class="card {{#if (eq this.type 'complaint')}}complaint{{/if}}">
      <span class="badge">{{this.type}}</span>
      <p><strong>Product:</strong> {{this.product_id.name}}</p>
      <p>{{this.message}}</p>
      <small>{{this.device_info}}</small>
    </div>
  {{/each}}
</section>
