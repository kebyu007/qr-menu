<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>QR Menu</title>
	<style>
		:root { color-scheme: dark; }
		* { box-sizing: border-box; }
		body { margin: 0; font-family: Inter, Arial, sans-serif; background: radial-gradient(circle at 20% -10%, #1e293b 0%, #020617 60%); color: #e2e8f0; }
		.container { max-width: 1120px; margin: 0 auto; padding: 28px 20px 40px; }
		.nav { position: sticky; top: 0; z-index: 5; background: rgba(2, 6, 23, 0.9); color: #fff; padding: 12px 20px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid rgba(148, 163, 184, 0.2); backdrop-filter: blur(8px); }
		.nav-group { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
		.nav-left { min-width: 140px; }
		.nav-center { flex: 1; justify-content: center; }
		.nav-right { min-width: 220px; justify-content: flex-end; }
		.brand { font-weight: 800; letter-spacing: 0.3px; color: #fff; text-decoration: none; padding: 8px 10px; }
		.nav a { color: #cbd5e1; text-decoration: none; font-weight: 600; padding: 8px 12px; border-radius: 8px; transition: 0.2s; }
		.nav a:hover { color: #fff; background: rgba(148, 163, 184, 0.22); }
		.nav .cta { background: #2563eb; color: #fff; }
		.nav .cta:hover { background: #1d4ed8; }
		.page-title { margin: 0 0 10px; font-size: 34px; letter-spacing: -0.6px; }
		.page-subtitle { margin: 0; color: #94a3b8; }
		.section { margin-bottom: 18px; }
		.card { background: #0f172a; border: 1px solid #334155; border-radius: 14px; padding: 18px; margin-bottom: 16px; box-shadow: 0 8px 24px rgba(2, 6, 23, 0.35); }
		.card h2, .card h3 { margin-top: 0; margin-bottom: 10px; }
		.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 14px; }
		.grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px; }
		.grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; }
		.btn { background: #2563eb; color: #fff; border: none; padding: 10px 14px; border-radius: 10px; cursor: pointer; font-weight: 600; }
		.btn:hover { background: #1d4ed8; }
		.btn-soft { background: #1e293b; border: 1px solid #334155; }
		.btn-soft:hover { background: #334155; }
		.input, select, textarea { color: #e2e8f0; width: 100%; padding: 10px 11px; margin-top: 6px; margin-bottom: 12px; border: 1px solid #475569; border-radius: 10px; background: #0b1220; }
		.muted { color: #94a3b8; font-size: 14px; }
		.badge { display: inline-block; padding: 4px 9px; border-radius: 999px; font-size: 12px; background: #1e293b; color: #a5b4fc; font-weight: 600; }
		.complaint { background: #3f1d2e; border-color: #be185d; }
		.panel { border: 1px solid #334155; background: linear-gradient(180deg, rgba(15,23,42,0.92), rgba(15,23,42,0.72)); border-radius: 16px; padding: 16px; }
		.auth-wrap { max-width: 520px; margin: 28px auto; }
		.auth-header { text-align: center; margin-bottom: 14px; }
		.auth-header .page-subtitle { margin: 0 auto; max-width: 420px; }
		.auth-card { padding: 24px; }
		.auth-card h2 { text-align: center; margin-bottom: 16px; }
		.auth-card .btn { display: block; width: 100%; margin-top: 4px; }
		.auth-links { text-align: center; margin-top: 12px; color: #94a3b8; }
		.auth-links a { color: #93c5fd; text-decoration: none; }
		.auth-links a:hover { text-decoration: underline; }
		.hero { display: flex; justify-content: space-between; align-items: end; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
		.hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
		.product-card img { width: 100%; max-height: 180px; object-fit: cover; border-radius: 10px; border: 1px solid #334155; }
		.toast-wrap { position: fixed; top: 76px; right: 16px; z-index: 20; display: flex; flex-direction: column; gap: 10px; }
		.toast { min-width: 260px; max-width: 360px; padding: 12px 14px; border-radius: 12px; border: 1px solid transparent; box-shadow: 0 10px 24px rgba(2, 6, 23, 0.45); animation: slideIn 0.25s ease-out; }
		.toast-error { color: #fecaca; background: #3f1d2e; border-color: #be123c; }
		.toast-success { color: #bbf7d0; background: #052e16; border-color: #15803d; }
		@keyframes slideIn { from { opacity: 0; transform: translateX(12px); } to { opacity: 1; transform: translateX(0); } }
		@media (max-width: 900px) {
			.nav { flex-direction: column; align-items: stretch; }
			.nav-left, .nav-center, .nav-right { width: 100%; justify-content: center; }
		}
		@media (max-width: 768px) { .page-title { font-size: 28px; } .container { padding-top: 20px; } }
	</style>
</head>
<body>
	<nav class="nav">
		<div class="nav-group nav-left">
			<a class="brand" href="/menu">QR Menu</a>
		</div>
		<div class="nav-group nav-center">
			<a href="/menu">Menu</a>
			<a href="/feedback">Feedback</a>
			{{#if currentUser}}
				<a href="/profile">Profile</a>
				{{#if (eq currentUser.role "ADMIN")}}
					<a href="/admin/dashboard">Dashboard</a>
				{{/if}}
			{{/if}}
		</div>
		<div class="nav-group nav-right">
			{{#if currentUser}}
				{{#if (eq currentUser.role "ADMIN")}}
					<a class="cta" href="/admin/dashboard#create-product">Create</a>
				{{/if}}
			{{else}}
				<a href="/login">Login</a>
				<a href="/register">Register</a>
			{{/if}}
		</div>
	</nav>
	<div class="toast-wrap">
		{{#if error}}
			<div class="toast toast-error">{{error}}</div>
		{{/if}}
		{{#if message}}
			<div class="toast toast-success">{{message}}</div>
		{{/if}}
	</div>
	<main class="container">
	{{{body}}}
	</main>
	<script>
		setTimeout(() => {
			document.querySelectorAll(".toast").forEach((el) => {
				el.style.opacity = "0";
				el.style.transform = "translateX(12px)";
			});
		}, 3200);
	</script>
</body>
</html>