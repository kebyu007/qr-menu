<style>
  .auth-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem; }
  .auth-box { width: 100%; max-width: 440px; animation: fadeUp 0.6s ease; }
  .auth-icon { width: 72px; height: 72px; background: var(--gold); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 1.5rem; }
  .auth-title { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: var(--brown); margin-bottom: 0.5rem; }
  .auth-sub { color: var(--text-muted); margin-bottom: 2rem; }
</style>

<div class="auth-page">
  <div class="auth-box">
    <div class="auth-icon">🔒</div>
    <div class="auth-title">Yangi parol</div>
    <div class="auth-sub">Yangi parolingizni kiriting</div>


    <form action="/api/auth/reset-password?userId={{userId}}&signed={{signed}}" method="POST">
      <div class="form-group">
        <label class="form-label">Yangi parol</label>
        <input type="password" name="password" class="form-control" placeholder="Kamida 6 belgi" required>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding: 0.85rem;">
        Saqlash
      </button>
    </form>
  </div>
</div>
