<style>
  .auth-page { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:2rem 1.25rem; }
  .auth-box { width:100%; max-width:440px; animation:fadeUp 0.5s ease; }
  .auth-icon { width:64px; height:64px; background:var(--gold); border-radius:18px; display:flex; align-items:center; justify-content:center; font-size:1.8rem; margin-bottom:1.25rem; }
  .auth-title { font-family:'Playfair Display',serif; font-size:1.9rem; font-weight:700; color:var(--brown); margin-bottom:0.4rem; }
  .auth-sub { color:var(--text-muted); margin-bottom:1.75rem; }
</style>
<div class="auth-page">
  <div class="auth-box">
    <div class="auth-icon">🔒</div>
    <div class="auth-title">Yangi parol</div>
    <div class="auth-sub">Yangi parolingizni kiriting</div>
    <form action="/api/auth/reset-password?userId={{userId}}&signed={{signed}}" method="POST">
      <div class="form-group">
        <label class="form-label">Yangi parol</label>
        <input type="password" name="password" class="form-control" placeholder="Kamida 6 belgi" required autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn-primary btn-block">Saqlash</button>
    </form>
  </div>
</div>
